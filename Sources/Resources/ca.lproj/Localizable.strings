/* MARK: - Upgrade FAQ View */
/* Titles */
"upgrade_faq_view_title" = "Preguntes freqüents";

/* Sections */
"upgrade_faq_general_section_title" = "General";
"upgrade_faq_purchases_section_title" = "Compres i subscripcions";

/* Items */
"upgrade_faq_about_title" = "Què és Budget Flow?";
"upgrade_faq_about_value" = "Budget Flow és una app de seguiment de pressupost moderna i fàcil d'utilitzar per a tots els que vulguin fer un seguiment de les seves finances i gestionar les seves despeses de manera efectiva.";
"upgrade_faq_developer_title" = "Qui va desenvolupar l'aplicació?";
"upgrade_faq_developer_value" = "Budget Flow va començar com un projecte secundari i des de llavors ha estat completament dissenyat, desenvolupat i mantingut per mi, Fabian Hasse. Sóc un desenvolupador de programari apassionat amb més de 10 anys d'experiència i treballo amb molta passió per desenvolupar la millor aplicació de seguiment de despeses i pressupostos a l'App Store.";
"upgrade_faq_free_use_title" = "Es pot utilitzar l'app també de forma gratuïta?";
"upgrade_faq_free_use_value" = "Sí, pots utilitzar les funcions bàsiques de l'app, com la creació de transaccions, de manera totalment gratuïta.\n\nA més, l'app ofereix un període de prova per a la versió completa perquè puguis provar-la abans de decidir-te a comprar-la o subscriure't a la versió completa.";
"upgrade_faq_security_title" = "Són segurs les meves dades?";
"upgrade_faq_security_value" = "Les teves finances són privades i així han de seguir sent. Per això, les teves dades s'emmagatzemen exclusivament al teu dispositiu o (opcionalment) al teu iCloud personal.";
"upgrade_faq_why_subscription_title" = "Per què la versió completa s'ofereix com a subscripció?";
"upgrade_faq_why_subscription_value" = "El meu objectiu és desenvolupar una app d'alta qualitat que t'ofereixi, com a usuari, noves funcions i millores de forma regular. No obstant això, per aconseguir aquest objectiu, l'app necessita ingressos continus per finançar-se i ser econòmicament sostenible.\n\nEl que molts no saben: Desenvolupar i mantenir una app requereix molt de temps. En el cas de Budget Flow, per exemple, van ser necessaris gairebé dos anys i diversos milers d'hores de treball des de la idea fins al desenvolupament i les proves abans que la primera versió es pogués llançar a l'App Store.\n\nCom a client, et beneficies especialment d'actualitzacions i millores periòdiques a través del model de subscripció, així com d'un bon suport per garantir que estiguis satisfet. També tens l'oportunitat de provar l'app gratuïtament per endavant per assegurar-te que s'adapti a les teves necessitats, i pots canviar o cancel·lar la subscripció en qualsevol moment si canvies d'opinió.\n\nEn general, un model de subscripció t'ofereix molts beneficis com a client i una millor experiència d'usuari mitjançant actualitzacions i suport continu, en comparació amb una compra única. A llarg termini, una compra única desafortunadament no seria sostenible, ja que aquest model de negoci requereix que els nous usuaris continuïn comprant l'app per garantir la continuïtat del desenvolupament.\n\nAixí que si t'agrada l'app, estaria molt feliç si recolzes el meu treball perquè pugui continuar oferint-te encara més funcions excel·lents en el futur! ❤️";
"upgrade_faq_multiple_devices_title" = "Puc utilitzar la versió completa en diversos dispositius?";
"upgrade_faq_multiple_devices_value" = "Sí, pots utilitzar la versió completa de Budget Flow a tots els teus dispositius Apple amb el mateix ID d'Apple. Com que l'app es sincronitza a través d'iCloud, pots canviar sense problemes entre els teus dispositius i tenir sempre accés a les teves dades i configuracions financeres.";
"upgrade_faq_multiple_people_title" = "Puc utilitzar la versió completa amb diverses persones?";
"upgrade_faq_multiple_people_value" = "Sí, pots compartir la compra única, així com la subscripció de la versió completa amb fins a cinc persones dins d'un grup familiar. Tot el que has de fer és activar el compartir en família a la configuració del sistema i afegir les altres persones al grup.";
"upgrade_faq_cancel_subscription_title" = "Com cancel·lo la meva subscripció?";
"upgrade_faq_cancel_subscription_value" = "Pots cancel·lar la teva subscripció en qualsevol moment utilitzant el teu ID d'Apple a les preferències del sistema.";
"upgrade_faq_subscription_data_loss_title" = "Perdré les meves dades si cancel·lo la subscripció?";
"upgrade_faq_subscription_data_loss_value" = "No. Tot el que creïs mentre estàs subscrit a la versió completa seguirà disponible si tornes a la versió gratuïta.";
"upgrade_faq_refund_title" = "Com puc obtenir un reemborsament?";
"upgrade_faq_refund_value" = "Els pagaments realitzats a través de l'App Store només són reemborsables per Apple. Per rebre un reemborsament, has de contactar amb el Suport tècnic d'Apple dins dels 14 dies posteriors a la compra.";
"upgrade_faq_switch_plan_title" = "És possible canviar d'una subscripció a una compra única en una data posterior?";
"upgrade_faq_switch_plan_value" = "Sí, pots canviar d'una subscripció activa a la compra única en qualsevol moment comprant el producte corresponent a l'app. No obstant això, recorda cancel·lar la teva subscripció anterior per no pagar més d'una vegada.";


