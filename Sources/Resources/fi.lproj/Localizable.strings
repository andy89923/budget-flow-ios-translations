/* Items */
"upgrade_faq_about_title" = "Mikä on Budget Flow?";
"upgrade_faq_about_value" = "Budget Flowus on moderni ja helppokäyttöinen budjetinseurantasovellus kaikille, jotka haluavat seurata talouttaan ja hallita kulujaan tehokkaasti.";
"upgrade_faq_developer_title" = "Kuka on kehittänyt sovelluksen?";
"upgrade_faq_developer_value" = "Budget Flow aloitettiin sivuprojektina, ja sen olen sittemmin suunnitellut, kehittänyt ja ylläpitänyt kokonaan minä, Fabian Hasse. Olen innostunut ohjelmistokehittäjä, jolla on yli 10 vuoden kokemus ja työskentelen suurella intohimolla kehittää paras budjetointi- ja kuluseurantasovellus App Storessa.";
"upgrade_faq_free_use_title" = "Voiko sovellusta käyttää myös ilmaiseksi?";
"upgrade_faq_free_use_value" = "Kyllä, voit käyttää sovelluksen perustoimintoja, kuten tapahtumien luomista, täysin ilmaiseksi.\n\nLisäksi sovellus tarjoaa kokeilujakson täysversiolle, jotta voit kokeilla sitä etukäteen ennen kuin päätät ostaa tai tilata täyden version.";
"upgrade_faq_security_title" = "Ovatko tietoni turvassa?";
"upgrade_faq_security_value" = "Talousi on yksityistä – ja sen pitäisi pysyä sellaisina. Siksi tietosi tallennetaan yksinomaan laitteellesi tai (valinnaisesti) henkilökohtaiseen iCloudiisi.";
"upgrade_faq_why_subscription_title" = "Miksi täysversio tarjotaan tilauksena?";
"upgrade_faq_why_subscription_value" = "Tavoitteenamme on kehittää korkealaatuinen sovellus, joka tarjoaa sinulle käyttäjänä uusia ominaisuuksia ja parannuksia säännöllisesti. Tämän tavoitteen saavuttamiseksi sovellus tarvitsee kuitenkin jatkuvaa tuloa voidakseen rahoittaa itsensä ja olla taloudellisesti kestävä.\n\nMitä monet eivät tiedä Sovelluksen kehittäminen ja ylläpito vie paljon aikaa. Esimerkiksi Budget Flow'n tapauksessa ideasta kehitykseen kesti lähes kaksi vuotta ja useita tuhansia työtunteja ja testaus ennen kuin ensimmäinen versio voidaan julkaista App Storessa.\n\nAsiakkaana hyödyt erityisesti tilausmallin säännöllisistä päivityksistä ja parannuksista sekä hyvästä tuesta, jotta voit varmistaa, että olet edelleen tyytyväinen. sinulla on myös mahdollisuus kokeilla sovellusta ilmaiseksi etukäteen varmistaaksesi, että se sopii tarpeisiisi. Voit muuttaa tilausta tai peruuttaa sen milloin tahansa, jos muutat mieltäsi.\n\nKaiken kaikkiaan tilausmalli tarjoaa sinulle monia etuja asiakas ja parempi käyttökokemus jatkuvien päivitysten ja tuen ansiosta verrattuna kertaostokseen. Pitkällä tähtäimellä kertaostos ei valitettavasti olisi kestävää, koska tämä liiketoimintamalli edellyttää uusien käyttäjien ostavan sovelluskehityksen jatkumisen.\n\nJos pidät sovelluksesta, olisimme erittäin iloisia jos tuet työtämme, jotta voimme jatkossakin tarjota sinulle entistä enemmän mahtavia ominaisuuksia!❤️";
"upgrade_faq_multiple_devices_title" = "Voinko käyttää täyttä versiota useissa laitteissa?";
"upgrade_faq_multiple_devices_value" = "Kyllä, voit käyttää Budget Flow'n täyttä versiota kaikissa Apple-laitteissasi samalla Apple ID:llä. Koska sovellus synkronoidaan iCloudin kautta, voit vaihtaa saumattomasti laitteidesi välillä ja saada aina pääsyn taloustietoihisi. ja asetukset.";
"upgrade_faq_multiple_people_title" = "Voinko käyttää täyttä versiota useiden ihmisten kanssa?";
"upgrade_faq_multiple_people_value" = "Kyllä, voit jakaa kertaostoksen sekä täysversion tilauksen jopa viiden henkilön kanssa perheryhmässä. Sinun tarvitsee vain ottaa perhejako käyttöön järjestelmäasetuksista ja lisätä muut ryhmän ihmiset kutsuvat.";
"upgrade_faq_cancel_subscription_title" = "Kuinka peruutan tilaukseni?";
"upgrade_faq_cancel_subscription_value" = "Voit peruuttaa tilauksesi milloin tahansa käyttämällä Apple ID:täsi Järjestelmäasetuksissa.";
"upgrade_faq_subscription_data_loss_title" = "Menevätkö tietoni, jos peruutan tilaukseni?";
"upgrade_faq_subscription_data_loss_value" = "Ei. Kaikki, mitä luot tilattaessa täysversiota, on edelleen saatavilla, jos vaihdat takaisin ilmaiseen versioon.";
"upgrade_faq_refund_title" = "Kuinka saan hyvityksen?";
"upgrade_faq_refund_value" = "Ainoastaan ​​Apple hyvittää App Storen kautta tehdyt maksut. Saadaksesi hyvityksen, sinun on otettava yhteyttä Applen tukeen 14 päivän kuluessa ostosta.";
"upgrade_faq_switch_plan_title" = "Onko mahdollista vaihtaa tilauksesta kertaostokseen myöhemmin?";
"upgrade_faq_switch_plan_value" = "Kyllä, voit vaihtaa aktiivisesta tilauksesta kertaostokseen milloin tahansa ostamalla vastaavan tuotteen sovelluksesta. Muista kuitenkin peruuttaa edellinen tilauksesi, jotta et maksa enempää kuin kerran.";


