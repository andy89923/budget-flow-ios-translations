/* Items */
"upgrade_faq_about_title" = "Šta je Budget Flow?";
"upgrade_faq_about_value" = "Budget Flow je moderna aplikacija za praćenje budžeta jednostavna za korištenje za sve koji žele pratiti svoje financije i učinkovito upravljati svojim troškovima.";
"upgrade_faq_developer_title" = "Tko je razvio aplikaciju?";
"upgrade_faq_developer_value" = "Budget Flow je pokrenut kao sporedni projekt i od tada sam ga u potpunosti dizajnirao, razvio i održavao ja, Fabian Hasse. Ja sam entuzijastični programer softvera s više od 10 godina iskustva i radim s puno strasti razviti najbolju aplikaciju za proračun i praćenje troškova u App Storeu.";
"upgrade_faq_free_use_title" = "Može li se aplikacija koristiti besplatno?";
"upgrade_faq_free_use_value" = "Da, možete koristiti osnovne funkcije aplikacije, kao što je stvaranje transakcija, potpuno besplatno.\n\nOsim toga, aplikacija nudi probno razdoblje za punu verziju tako da je možete isprobati unaprijed prije nego što odlučite kupiti ili se pretplatiti na punu verziju.";
"upgrade_faq_security_title" = "Jesu li moji podaci sigurni?";
"upgrade_faq_security_value" = "Vaše su financije privatne – i trebale bi takve i ostati. Zato se vaši podaci pohranjuju isključivo na vašem uređaju ili (po izboru) u vašem osobnom iCloudu.";
"upgrade_faq_why_subscription_title" = "Zašto se puna verzija nudi kao pretplata?";
"upgrade_faq_why_subscription_value" = "Naš cilj je razviti visokokvalitetnu aplikaciju koja vam kao korisniku redovito nudi nove značajke i poboljšanja. Međutim, kako bi se postigao ovaj cilj, aplikaciji su potrebni stalni prihodi kako bi se financirao kontinuirani razvoj.\n\nOno što mnogi ne znaju jeste da razvoj i održavanje aplikacija zahtijeva puno vremena. U slučaju Budget Flow, na primjer, od ideje do razvoja bile su potrebne gotovo dvije godine i nekoliko tisuća sati rada i testiranje prije nego što se prva verzija mogla objaviti u App Store.\n\nKao kupac, posebno imate koristi od redovitih ažuriranja i poboljšanja putem modela pretplate, kao i dobre podrške kako biste bili sigurni da ćete i dalje biti zadovoljni. Također imate priliku isprobati aplikaciju besplatno unaprijed kako biste bili sigurni da odgovara vašim potrebama. Možete promijeniti ili otkazati pretplatu u bilo kojem trenutku ako se predomislite.\n\nSve u svemu, model pretplate nudi mnoge pogodnosti za vas kao kupca i bolje korisničko iskustvo kroz stalna ažuriranja i podršku u usporedbi s jednokratnom kupnjom. Dugoročno gledano, jednokratna kupnja nažalost ne bi bila održiva jer ovaj poslovni model zahtijeva da novi korisnici nastave kupovati aplikaciju kako bi se osigurao nastavak razvoja.\n\nDakle, ako vam se aplikacija sviđa, bili bi mnogo zahvalni kada biste podržavali naš rad, jer bi vam mogli nastaviti nuditi još sjajnijih značajki u budućnosti!❤️";
"upgrade_faq_multiple_devices_title" = "Mogu li koristiti punu verziju na više uređaja?";
"upgrade_faq_multiple_devices_value" = "Da, možete koristiti punu verziju Budget Flow-a na svim svojim Apple uređajima s istim Apple ID-om. Budući da je aplikacija sinkronizirana putem iClouda, možete se neprimjetno prebacivati ​​između svojih uređaja i uvijek imati pristup svojim financijskim podacima i postavke.";
"upgrade_faq_multiple_people_title" = "Mogu li koristiti punu verziju s više osoba?";
"upgrade_faq_multiple_people_value" = "Da, možete podijeliti jednokratnu kupnju kao i pretplatu na punu verziju s do pet osoba unutar obiteljske grupe. Sve što trebate učiniti je uključiti obiteljsko dijeljenje u postavkama sustava i dodati druge osobe u grupi pozivaju.";
"upgrade_faq_cancel_subscription_title" = "Kako mogu otkazati svoju pretplatu?";
"upgrade_faq_cancel_subscription_value" = "Možete otkazati svoju pretplatu u bilo kojem trenutku koristeći svoj Apple ID u postavkama sustava.";
"upgrade_faq_subscription_data_loss_title" = "Hoće li moji podaci biti izgubljeni ako otkažem svoju pretplatu?";
"upgrade_faq_subscription_data_loss_value" = "Ne. Sve što stvorite tijekom pretplate na punu verziju i dalje će biti dostupno ako se vratite na besplatnu verziju.";
"upgrade_faq_refund_title" = "Kako mogu dobiti povrat novca?";
"upgrade_faq_refund_value" = "Plaćanja izvršena putem App Store mogu se povratiti samo od strane Applea. Da biste dobili povrat, morate kontaktirati Apple podršku u roku od 14 dana od kupnje.";
"upgrade_faq_switch_plan_title" = "Je li moguće kasnije prijeći s pretplate na jednokratnu kupnju?";
"upgrade_faq_switch_plan_value" = "Da, možete se prebaciti s aktivne pretplate na jednokratnu kupnju u bilo kojem trenutku kupnjom odgovarajućeg proizvoda u aplikaciji. Međutim, ne zaboravite otkazati prethodnu pretplatu kako ne biste platili više od jednom.";


