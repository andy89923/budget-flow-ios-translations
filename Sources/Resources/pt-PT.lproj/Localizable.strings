/* MARK: - Upgrade FAQ View */
/* Titles */
"upgrade_faq_view_title" = "FAQ";

/* Sections */
"upgrade_faq_general_section_title" = "Geral";
"upgrade_faq_purchases_section_title" = "Compras e subscrições";

/* Items */
"upgrade_faq_about_title" = "O que é o Budget Flow?";
"upgrade_faq_about_value" = "Budget Flow é uma aplicação de rastreamento de orçamento moderna e fácil de usar para todos que querem acompanhar as tuas finanças e gerir as tuas despesas de forma eficaz.";
"upgrade_faq_developer_title" = "Quem desenvolveu a aplicação?";
"upgrade_faq_developer_value" = "O Budget Flow foi iniciado como um projeto paralelo e desde então foi completamente concebido, desenvolvido e mantido por mim, Fabian Hasse. Sou um programador de software entusiasta com mais de 10 anos de experiência e trabalho com muita paixão para desenvolver a melhor aplicação de orçamento e controlo de despesas na App Store.";
"upgrade_faq_free_use_title" = "A aplicação também pode ser usada gratuitamente?";
"upgrade_faq_free_use_value" = "Sim, podes usar as funções básicas da aplicação, como criar transações, de forma totalmente gratuita.\n\nAlém disso, a aplicação oferece um período de teste para a versão completa para que possas experimentá-la com antecedência antes de decidires comprar ou subscrever a versão completa.";
"upgrade_faq_security_title" = "Os meus dados estão seguros?";
"upgrade_faq_security_value" = "As tuas finanças são privadas – e devem permanecer assim. É por isso que os teus dados são armazenados exclusivamente no teu dispositivo ou (opcionalmente) no teu iCloud pessoal.";
"upgrade_faq_why_subscription_title" = "Por que a versão completa é oferecida como uma subscrição?";
"upgrade_faq_why_subscription_value" = "O meu objetivo é desenvolver uma aplicação de alta qualidade que te ofereça como utilizador novos recursos e melhorias regularmente. No entanto, para atingir esse objetivo, a aplicação precisa de receita contínua para se financiar e ser economicamente sustentável.\n\nO que muitos não sabem: desenvolver e manter uma aplicação leva muito tempo. No caso do Budget Flow, por exemplo, foram necessários quase dois anos e milhares de horas de trabalho desde a ideia até o desenvolvimento e testes até que a primeira versão pudesse ser lançada na App Store.\n\nComo cliente, beneficias em particular de atualizações e melhorias regulares através do modelo de subscrição, bem como um bom suporte para garantir que continues satisfeito. Também tens a oportunidade de experimentar a aplicação gratuitamente com antecedência para garantir que ela atende às tuas necessidades, podes alterar ou cancelar a subscrição a qualquer momento se mudares de ideias.\n\nNo geral, um modelo de subscrição oferece muitos benefícios para ti como cliente e uma melhor experiência do utilizador por meio de atualizações contínuas e suporte em comparação com uma compra única. A longo prazo, uma compra única infelizmente não seria sustentável, pois esse modelo de negócio exige que novos utilizadores continuem a comprar a aplicação para garantir a continuação do desenvolvimento.\n\nEntão, se gostas da aplicação, ficaria muito feliz se apoiasses o meu trabalho para que eu possa continuar a oferecer ainda mais recursos excelentes no futuro!❤️";
"upgrade_faq_multiple_devices_title" = "Posso usar a versão completa em vários dispositivos?";
"upgrade_faq_multiple_devices_value" = "Sim, podes usar a versão completa do Budget Flow em todos os teus dispositivos Apple com o mesmo ID Apple. Uma vez que a aplicação é sincronizada através do iCloud, podes alternar facilmente entre os teus dispositivos e ter sempre acesso aos teus dados financeiros e configurações.";
"upgrade_faq_multiple_people_title" = "Posso usar a versão completa com várias pessoas?";
"upgrade_faq_multiple_people_value" = "Sim, podes partilhar a compra única, bem como a subscrição da versão completa com até cinco pessoas dentro de um grupo familiar. Tudo o que tens de fazer é ativar a partilha familiar nas configurações do sistema e adicionar as outras pessoas ao grupo.";
"upgrade_faq_cancel_subscription_title" = "Como posso cancelar a minha subscrição?";
"upgrade_faq_cancel_subscription_value" = "Podes cancelar a tua subscrição a qualquer momento utilizando o teu ID Apple nas preferências do sistema.";
"upgrade_faq_subscription_data_loss_title" = "Os meus dados serão perdidos se eu cancelar a minha subscrição?";
"upgrade_faq_subscription_data_loss_value" = "Não. Qualquer coisa que cries ao subscrever a versão completa ainda estará disponível se voltares para a versão gratuita.";
"upgrade_faq_refund_title" = "Como posso obter um reembolso?";
"upgrade_faq_refund_value" = "Pagamentos feitos através da App Store são reembolsáveis apenas pela Apple. Para receber um reembolso, tens de contactar o Suporte Apple no prazo de 14 dias após a compra.";
"upgrade_faq_switch_plan_title" = "É possível mudar de uma subscrição para uma compra única posteriormente?";
"upgrade_faq_switch_plan_value" = "Sim, podes mudar de uma subscrição ativa para uma compra única a qualquer momento, comprando o produto correspondente na aplicação. No entanto, lembra-te de cancelar a tua subscrição anterior para não pagares mais do que uma vez.";


