/* MARK: - Upgrade FAQ View */
/* Titles */
"upgrade_faq_view_title" = "FAQ";

/* Sections */
"upgrade_faq_general_section_title" = "Tổng quan";
"upgrade_faq_purchases_section_title" = "Mua hàng & đăng ký";

/* Items */
"upgrade_faq_about_title" = "Budget Flow là gì?";
"upgrade_faq_about_value" = "Budget Flow là một ứng dụng theo dõi thu nhập hiện đại và dễ sử dụng dành cho tất cả những ai muốn theo dõi và quản lý chi tiêu một cách hiệu quả.";
"upgrade_faq_developer_title" = "Ai đã phát triển ứng dụng?";
"upgrade_faq_developer_value" = "Budget Flow được bắt đầu như một dự án phụ và kể từ đó đã được tôi, Fabian Hasse, thiết kế, phát triển và bảo trì hoàn toàn. Tôi là một nhà phát triển phần mềm nhiệt tình với hơn 10 năm kinh nghiệm và tôi làm việc với rất nhiều đam mê để phát triển ứng dụng theo dõi chi phí và lập ngân sách tốt nhất trên App Store.";
"upgrade_faq_free_use_title" = "Ứng dụng có bản miễn phí không?";
"upgrade_faq_free_use_value" = "Có, bạn có thể sử dụng các chức năng cơ bản của ứng dụng, chẳng hạn như tạo giao dịch, hoàn toàn miễn phí.\n\nNgoài ra, ứng dụng còn cung cấp thời gian dùng thử cho phiên bản Premium để bạn có thể dùng thử trước trước khi quyết định mua hoặc đăng ký phiên bản Premium.";
"upgrade_faq_security_title" = "Dữ liệu của tôi có an toàn không?";
"upgrade_faq_security_value" = "Tài chính của bạn là riêng tư – và chúng phải được duy trì như vậy. Đó là lý do tại sao dữ liệu của bạn được lưu trữ riêng trên thiết bị của bạn hoặc (tùy chọn) trong iCloud cá nhân của bạn.";
"upgrade_faq_why_subscription_title" = "Tại sao tôi phải đăng ký để có thể sử dụng phiên bản Premium?";
"upgrade_faq_why_subscription_value" = "Mục tiêu của chúng tôi là phát triển một ứng dụng chất lượng cung cấp cho bạn các tính năng và cải tiến mới một cách thường xuyên. Tuy nhiên, để đạt được mục tiêu này, ứng dụng cần có doanh thu liên tục để tự cấp vốn và bền vững về mặt kinh tế.\n\nĐiều nhiều người không biết: Việc phát triển và duy trì một ứng dụng mất rất nhiều thời gian. Ví dụ: trong trường hợp của Budget Flow, phải mất gần hai năm và vài nghìn giờ làm việc từ ý tưởng đến phát triển và thử nghiệm trước khi phiên bản đầu tiên có thể được phát hành trên App Store.\n\nLà khách hàng, bạn được hưởng lợi đặc biệt từ các bản cập nhật và cải tiến thường xuyên thông qua mô hình đăng ký, cũng như hỗ trợ tốt để đảm bảo rằng bạn tiếp tục hài lòng. Bạn cũng có cơ hội dùng thử ứng dụng miễn phí trước để đảm bảo ứng dụng phù hợp với nhu cầu của bạn. Bạn có thể thay đổi hoặc hủy đăng ký bất kỳ lúc nào nếu thay đổi ý định.\n\nNhìn chung, mô hình đăng ký mang lại nhiều lợi ích cho bạn trải nghiệm người dùng tốt hơn thông qua cập nhật và hỗ trợ liên tục so với mua hàng một lần. Rất tiếc, về lâu dài, việc mua một lần sẽ không bền vững vì mô hình kinh doanh này yêu cầu người dùng mới phải tiếp tục mua ứng dụng để đảm bảo ứng dụng được tiếp tục phát triển.\n\nVì vậy, nếu bạn thích ứng dụng này, tôi sẽ rất vui nếu bạn ủng hộ ứng dụng để tôi có thể tiếp tục cung cấp cho bạn nhiều tính năng tuyệt vời hơn nữa trong tương lai! ❤️";
"upgrade_faq_multiple_devices_title" = "Tôi có thể dùng phiên bản Premium trên nhiều thiết bị không?";
"upgrade_faq_multiple_devices_value" = "Có, bạn có thể sử dụng phiên bản Premium của Budget Flow trên tất cả các thiết bị Apple có cùng ID Apple. Vì ứng dụng được đồng bộ hóa qua iCloud nên bạn có thể tương tác giữa các thiết bị của mình và luôn có quyền truy cập vào dữ liệu cũng như cài đặt tài chính của mình.";
"upgrade_faq_multiple_people_title" = "Tôi có thể sử dụng phiên bản Premium với nhiều người không?";
"upgrade_faq_multiple_people_value" = "Có, bạn có thể chia sẻ giao dịch mua một lần cũng như đăng ký phiên bản Premium với tối đa năm người trong một nhóm gia đình. Tất cả những gì bạn phải làm là bật tính năng chia sẻ gia đình trong cài đặt hệ thống và thêm những người khác vào nhóm.";
"upgrade_faq_cancel_subscription_title" = "Làm cách nào để hủy đăng ký của tôi?";
"upgrade_faq_cancel_subscription_value" = "Bạn có thể hủy đăng ký của mình bất kỳ lúc nào bằng cách sử dụng ID Apple trong ứng dụng Cài đặt của thiết bị Apple.";
"upgrade_faq_subscription_data_loss_title" = "Dữ liệu của tôi có bị mất nếu tôi hủy đăng ký không?";
