/* MARK: - Upgrade FAQ View */
/* Titles */
"upgrade_faq_view_title" = "FAQ";

/* Sections */
"upgrade_faq_general_section_title" = "Général";
"upgrade_faq_purchases_section_title" = "Achats et abonnements";

/* Items */
"upgrade_faq_about_title" = "Qu'est-ce que le Budget Flow";
"upgrade_faq_about_value" = "Budget Flow est une app de suivi budgétaire moderne et facile à utiliser pour tous ceux qui souhaitent suivre leurs finances et gérer efficacement leurs dépenses.";
"upgrade_faq_developer_title" = "Qui a développé l'application ?";
"upgrade_faq_developer_value" = "Budget Flow a été lancé en tant que projet parallèle et a depuis été entièrement conçu, développé et maintenu par moi, Fabian Hasse. Je suis un développeur de logiciels enthousiaste avec plus de 10 ans d'expérience et je travaille avec beaucoup de passion pour développer la meilleure application de budgétisation et de suivi des dépenses de l'App Store.";
"upgrade_faq_free_use_title" = "L'app peut-elle également être utilisée gratuitement ?";
"upgrade_faq_free_use_value" = "Oui, vous pouvez utiliser les fonctions de base de l'app, telle que la création de transactions, entièrement gratuitement.\n\nDe plus, l'app propose une période d'essai pour la version complète afin que vous puissiez l'essayer à l'avance avant de décider d'acheter ou de vous abonner à la version complète.";
"upgrade_faq_security_title" = "Mes données sont-elles sécurisées ?";
"upgrade_faq_security_value" = "Vos finances sont privées – et elles doivent le rester. C'est pourquoi vos données sont stockées exclusivement sur votre appareil ou (en option) dans votre iCloud personnel.";
"upgrade_faq_why_subscription_title" = "Pourquoi la version complète est-elle proposée sous forme d'abonnement ?";
"upgrade_faq_why_subscription_value" = "Notre objectif est de développer une app de haute qualité qui vous offre en tant qu'utilisateur de nouvelles fonctionnalités et améliorations sur une base régulière. Cependant, pour atteindre cet objectif, l'app a besoin de revenus continus pour se financer et être économiquement viable.\n\nCe que beaucoup ignorent: le développement et la maintenance d'une app prennent beaucoup de temps. Dans le cas de Budget Flow, par exemple, il a fallu près de deux ans et plusieurs milliers d'heures de travail, de l'idée au développement et aux tests, avant que la première version puisse être publiée sur l'App Store.\n\nEn tant que client, vous bénéficiez notamment des mises à jour et des améliorations régulières grâce au modèle d'abonnement, ainsi qu'un bon support pour continuellement vous satisfaire. Vous avez également la possibilité d'essayer l'app gratuitement à l'avance pour vous assurer qu'elle répond à vos besoins et modifier ou annuler l'abonnement à tout moment si vous changez d'avis.\n\nGlobalement, un modèle d'abonnement vous offre de nombreux avantages en tant que un client et une meilleure expérience utilisateur grâce à des mises à jour et un support continus par rapport à un achat unique. À long terme, un achat unique ne serait malheureusement pas viable, car ce modèle commercial oblige les nouveaux utilisateurs à continuer d'acheter l'app pour assurer la poursuite du développement.\n\nDonc, si vous aimez l'app, nous serions très heureux que vous souteniez notre travail afin que nous puissions continuer à vous offrir encore plus de fonctionnalités à l'avenir !❤️";
"upgrade_faq_multiple_devices_title" = "Puis-je utiliser la version complète sur plusieurs appareils ?";
"upgrade_faq_multiple_devices_value" = "Oui, vous pouvez utiliser la version complète de Budget Flow sur tous vos appareils Apple avec le même identifiant Apple. Étant donné que l'app est synchronisée via iCloud, vous pouvez facilement basculer entre vos appareils et avoir toujours accès à vos données financières et réglages.";
"upgrade_faq_multiple_people_title" = "Puis-je utiliser la version complète avec plusieurs personnes ?";
"upgrade_faq_multiple_people_value" = "Oui, vous pouvez partager l'achat unique ainsi que l'abonnement de la version complète avec jusqu'à cinq personnes au sein d'un groupe familial. Il vous suffit d'activer le partage familial dans les réglages système et d'ajouter les autres personnes du groupe à inviter.";
"upgrade_faq_cancel_subscription_title" = "Comment puis-je annuler mon abonnement ?";
"upgrade_faq_cancel_subscription_value" = "Vous pouvez annuler votre abonnement à tout moment en utilisant votre identifiant Apple dans les Préférences Système.";
"upgrade_faq_subscription_data_loss_title" = "Mes données seront-elles perdues si j'annule mon abonnement ?";
"upgrade_faq_subscription_data_loss_value" = "Non. Tout ce que vous créez en vous abonnant à la version complète sera toujours disponible si vous revenez à la version gratuite.";
"upgrade_faq_refund_title" = "Comment puis-je obtenir un remboursement ?";
"upgrade_faq_refund_value" = "Les paiements effectués via l'App Store ne sont remboursables que par Apple. Pour recevoir un remboursement, vous devez contacter l'assistance Apple dans les 14 jours suivant l'achat.";
"upgrade_faq_switch_plan_title" = "Est-il possible de passer ultérieurement d'un abonnement à un achat unique ?";
"upgrade_faq_switch_plan_value" = "Oui, vous pouvez passer d'un abonnement actif à un achat unique à tout moment en achetant le produit correspondant dans l'app. Cependant, n'oubliez pas d'annuler votre abonnement précédent afin de ne pas payer plus de une fois.";


