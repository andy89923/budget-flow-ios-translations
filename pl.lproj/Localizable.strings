/* Items */
"upgrade_faq_about_title" = "Co to jest Budget Flow?";
"upgrade_faq_about_value" = "Budget Flow to nowoczesna i łatwa w użyciu aplikacja do śledzenia budżetu dla każdego, kto chce śledzić swoje finanse i efektywnie zarządzać wydatkami.";
"upgrade_faq_developer_title" = "Kto opracował aplikację?";
"upgrade_faq_developer_value" = "Budget Flow był początkowo projektem pobocznym, jednak od tego czasu stał się w pełni rozwiniętą aplikacją, która jest utrzymywana przeze mnie, Fabiana Hasse. Jestem pasjonatem programowania z ponad 10-letnim doświadczeniem i z wielkim zaangażowaniem pracuję nad stworzeniem najlepszej aplikacji do zarządzania budżetem i śledzenia wydatków w App Store.";
"upgrade_faq_free_use_title" = "Czy z aplikacji można również korzystać za darmo?";
"upgrade_faq_free_use_value" = "Tak, możesz całkowicie bezpłatnie korzystać z podstawowych funkcji aplikacji, takich jak tworzenie transakcji.\n\nPonadto aplikacja oferuje okres próbny pełnej wersji, dzięki czemu możesz ją wypróbować z wyprzedzeniem zanim zdecydujesz się na zakup lub subskrypcję pełnej wersji.";
"upgrade_faq_security_title" = "Czy moje dane są bezpieczne?";
"upgrade_faq_security_value" = "Twoje finanse są prywatne – i powinny takie pozostać. Dlatego Twoje dane są przechowywane wyłącznie na Twoim urządzeniu lub (opcjonalnie) w Twoim osobistym iCloud.";
"upgrade_faq_why_subscription_title" = "Dlaczego pełna wersja jest oferowana jako subskrypcja?";
"upgrade_faq_why_subscription_value" = "Moim celem jest opracowanie wysokiej jakości aplikacji, która regularnie oferuje nowe funkcje i usprawnienia. Aby jednak osiągnąć ten cel, aplikacja musi generować stały przychód, by móc się finansować i być ekonomicznie zrównoważona. Wielu użytkowników nie zdaje sobie sprawy z tego, że tworzenie i utrzymywanie aplikacji zajmuje mnóstwo czasu. W przypadku Budget Flow, na przykład od pomysłu do gotowej wersji, która mogła zostać wydana w App Store, minęły prawie dwa lata i kilka tysięcy godzin pracy na etapie rozwoju i testowania. Dzięki modelowi subskrypcyjnemu, zyskujesz regularne aktualizacje i ulepszenia, a także wsparcie, aby zapewnić Ci ciągłą satysfakcję. Masz również możliwość wypróbowania aplikacji za darmo, aby upewnić się, że spełni Twoje oczekiwania. W każdej chwili możesz zmienić zdanie i anulować subskrypcję. Jednak, z uwagi na użytkowników, którzy nie przepadają za subskrypcjami, dostępna jest również opcja jednorazowego zakupu w nieco wyższej cenie. Cena jednorazowego zakupu wynosi około 2,5 razy więcej niż roczna subskrypcja. W związku z tym wszystkie przyszłe koszty związane z aktualizacjami i wsparciem są pokrywane przez dożywotnią wersję aplikacji, co w przypadku subskrypcji byłoby pokryte przez cykliczne opłaty. Ostatecznie ten model biznesowy zapewnia Ci, jako użytkownikowi, wiele korzyści i lepsze doświadczenie dzięki ciągłym aktualizacjom i wsparciu. W dłuższym okresie niski koszt jednorazowego zakupu niestety nie byłby zrównoważony, ponieważ ten model wymaga od nowych użytkowników ciągłego zakupu aplikacji, aby zapewnić jej rozwój. Jeśli podoba Ci się aplikacja, będę bardzo wdzięczny za wsparcie mojej pracy, dzięki któremu będę mógł zaoferować Ci jeszcze więcej wspaniałych funkcji w przyszłości! ❤️";
"upgrade_faq_multiple_devices_title" = "Czy mogę używać pełnej wersji na wielu urządzeniach?";
"upgrade_faq_multiple_devices_value" = "Tak, możesz używać pełnej wersji Budget Flow na wszystkich swoich urządzeniach Apple z tym samym Apple ID. Ponieważ aplikacja jest synchronizowana przez iCloud, możesz płynnie przełączać się między urządzeniami i zawsze mieć dostęp do swoich danych finansowych i ustawienia.";
"upgrade_faq_multiple_people_title" = "Czy mogę używać pełnej wersji z wieloma osobami?";
"upgrade_faq_multiple_people_value" = "Tak, jednorazowy zakup oraz subskrypcję pełnej wersji możesz udostępnić maksymalnie pięciu osobom w grupie rodzinnej. Wystarczy włączyć udostępnianie rodziny w ustawieniach systemu i dodać inne osoby zapraszając je do grupy.";
"upgrade_faq_cancel_subscription_title" = "Jak anulować subskrypcję?";
"upgrade_faq_cancel_subscription_value" = "Możesz anulować subskrypcję w dowolnym momencie, używając swojego Apple ID w Preferencjach systemowych.";
"upgrade_faq_subscription_data_loss_title" = "Czy moje dane zostaną utracone, jeśli anuluję subskrypcję?";
"upgrade_faq_subscription_data_loss_value" = "Nie. Wszystko, co utworzysz podczas subskrypcji pełnej wersji, będzie nadal dostępne, jeśli wrócisz do wersji darmowej.";
"upgrade_faq_refund_title" = "Jak mogę otrzymać zwrot pieniędzy?";
"upgrade_faq_refund_value" = "Płatności dokonane za pośrednictwem App Store są zwracane tylko przez Apple. Aby otrzymać zwrot, musisz skontaktować się z pomocą techniczną Apple w ciągu 14 dni od zakupu.";
"upgrade_faq_switch_plan_title" = "Czy można w późniejszym terminie przejść z subskrypcji na jednorazowy zakup?";
"upgrade_faq_switch_plan_value" = "Tak, w każdej chwili możesz przejść z aktywnej subskrypcji na jednorazowy zakup, kupując odpowiedni produkt w aplikacji. Pamiętaj jednak, aby anulować poprzednią subskrypcję, aby nie zapłacić więcej niż raz.";


